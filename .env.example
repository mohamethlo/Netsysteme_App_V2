# Copier ce fichier en backend/.env et adapter les valeurs

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=changez-moi-avec-une-cle-secrete-dau-moins-50-caracteres
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données MySQL (utilisé par Docker) ───────────────────────────────
DB_ENGINE=django.db.backends.mysql
DB_NAME=netsysteme_db
DB_USER=netsysteme
DB_PASSWORD=votre_mot_de_passe_securise
DB_HOST=db
DB_PORT=3306

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@gmail.com
EMAIL_HOST_PASSWORD=votre_app_password_gmail
DEFAULT_FROM_EMAIL=votre@gmail.com
REPORT_EMAIL_RECIPIENTS=destinataire@example.com

# ── SMS (Orange API) ─────────────────────────────────────────────────────────
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_SENDER_NAME=NETSYSTEME

ORANGE_CLIENT_ID_SSE=
ORANGE_CLIENT_SECRET_SSE=
ORANGE_SENDER_NAME_SSE=SSE
